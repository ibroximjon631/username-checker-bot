# Bot token — @BotFather'dan oling (MAJBURIY)
BOT_TOKEN=123456:ABC-DEF1234567890

# Bepul kunlik tekshiruv limiti
FREE_DAILY_LIMIT=20

# Admin Telegram ID'lari (vergul bilan ajrating)
ADMIN_IDS=

# --- Telethon (IXTIYORIY — aniq tekshiruv uchun) ---
# my.telegram.org -> API development tools
# Bo'sh qoldirsangiz bot faqat t.me bilan ishlaydi (baribir ishlaydi).
API_ID=0
API_HASH=
TELETHON_SESSION=username_checker

# --- Monitoring ---
# Watchlist qanchadan tekshiriladi (daqiqa)
CHECK_INTERVAL_MINUTES=10

# --- Fragment ---
# Sotuvdagi username narxini ko'rsatish (true/false)
FRAGMENT_ENABLED=true

# --- Ma'lumotlar bazasi ---
DB_PATH=bot.db
